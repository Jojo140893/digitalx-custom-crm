# DigitalX CRM — Supabase & Database Environment Configuration

# 1. Supabase Cloud Connection (URL & Anon Public Key)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# 2. Direct PostgreSQL Database Connection String (Prisma / Supabase)
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.your-project-id.supabase.co:5432/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.your-project-id.supabase.co:5432/postgres"

# Note: The CRM application automatically operates seamlessly with full stateful mock fallback
# when these variables are left empty or during local development!
